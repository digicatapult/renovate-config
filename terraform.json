{
	"$schema": "https://docs.renovatebot.com/renovate-schema.json",
	"extends": [
		"github>digicatapult/renovate-config"
	],
	"enabledManagers": [
		"terraform",
		"terragrunt",
		"terraform-version",
		"terragrunt-version",
		"github-actions"
	],
	"prHourlyLimit": 2,
	"prConcurrentLimit": 5,
	"schedule": [
		"* 9-17 * * 1-5"
	],
	"labels": [
		"dependencies"
	],
	"minimumReleaseAge": "3 days",
	"separateMajorMinor": true,
	"terraform": {
		"rangeStrategy": "bump",
		"addLabels": [
			"terraform"
		]
	},
	"terragrunt": {
		"rangeStrategy": "bump",
		"addLabels": [
			"terragrunt"
		],
		"lockFileMaintenance": {
			"enabled": true,
			"recreateWhen": "always",
			"rebaseWhen": "behind-base-branch",
			"branchTopic": "terraform-lock-maintenance",
			"schedule": [
				"after 12pm on sunday"
			],
			"addLabels": [
				"lock-files"
			]
		}
	},
	"terraform-version": {
		"addLabels": [
			"terraform",
			"tooling"
		]
	},
	"terragrunt-version": {
		"addLabels": [
			"terragrunt",
			"tooling"
		]
	},
	"packageRules": [
		{
			"description": "Group Terraform provider minor and patch updates into a single PR",
			"matchManagers": [
				"terraform"
			],
			"matchDepTypes": [
				"provider",
				"required_provider"
			],
			"matchUpdateTypes": [
				"minor",
				"patch"
			],
			"groupName": "terraform providers - minor and patch updates"
		},
		{
			"description": "Group Terraform module (registry/local) minor and patch updates",
			"matchManagers": [
				"terraform"
			],
			"matchDepTypes": [
				"module"
			],
			"matchUpdateTypes": [
				"minor",
				"patch"
			],
			"groupName": "terraform modules - minor and patch updates"
		},
		{
			"description": "Group Terragrunt module sources (registry/GitHub/Git) minor and patch updates",
			"matchManagers": [
				"terragrunt"
			],
			"matchDepTypes": [
				"terragrunt",
				"github",
				"gitTags"
			],
			"matchUpdateTypes": [
				"minor",
				"patch"
			],
			"groupName": "terragrunt modules - minor and patch updates"
		},
		{
			"description": "Label all major updates clearly so they stand out for review",
			"matchManagers": [
				"terraform",
				"terragrunt",
				"terraform-version",
				"terragrunt-version"
			],
			"matchUpdateTypes": [
				"major"
			],
			"addLabels": [
				"major-update"
			]
		}
	]
}
